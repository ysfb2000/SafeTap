<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_background">

    <Button
        android:id="@+id/btnSos"
        android:layout_width="110dp"
        android:layout_height="70dp"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/theme_sos"
        android:text="SOS"
        android:textColor="@color/theme_on_surface"
        android:textSize="24sp"
        android:textStyle="bold"
        app:cornerRadius="360dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="12dp"
        app:layout_boxedEdges="all">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button2"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="@color/theme_surface"
            app:cornerRadius="24dp"
            app:icon="@drawable/outline_person_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/theme_on_surface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGps"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="@color/theme_surface"
            app:cornerRadius="24dp"
            app:icon="@drawable/outline_globe_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/theme_on_surface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button4"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="@color/theme_surface"
            app:cornerRadius="24dp"
            app:icon="@drawable/outline_heart_check_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/theme_on_surface" />

    </LinearLayout>
</androidx.wear.widget.BoxInsetLayout>